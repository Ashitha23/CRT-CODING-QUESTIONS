ratings = list(map(int, input().split()))

count = 0
n = len(ratings)

for i in range(n):
    for j in range(i + 1, n):
        for k in range(j + 1, n):
            if ratings[i] < ratings[j] < ratings[k]:
                count += 1
            elif ratings[i] > ratings[j] > ratings[k]:
                count += 1

print(count)
