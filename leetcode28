Find the First Occurrence of a Substring
leetcode prblm no 28
inputs 
1 2 3 4 5 10 6 7 8 9
5
output 
true
code
# Simple Approach

arr = list(map(int, input().split()))
k = int(input())

used = [False] * len(arr)
possible = True

for i in range(len(arr)):
    if used[i]:
        continue

    found = False

    for j in range(i + 1, len(arr)):
        if not used[j] and (arr[i] + arr[j]) % k == 0:
            used[i] = True
            used[j] = True
            found = True
            break

    if not found:
        possible = False
        break

print(possible)
